{
  "version": 1,
  "serviceConfiguration": {
    "apiName": "RukuAPI",
    "serviceName": "AppSync",
    "defaultAuthType": {
      "mode": "AMAZON_COGNITO_USER_POOLS",
      "cognitoUserPoolId": "authRukuAuth"
    },
    "additionalAuthTypes": [
      {
        "mode": "API_KEY",
        "expirationTime": 30,
        "apiKeyExpirationDate": "2023-07-15T15:10:36.034Z",
        "keyDescription": "Api key used to access RukuAPI"
      },
      {
        "mode": "AWS_IAM"
      }
    ],
    "conflictResolution": {
      "defaultResolutionStrategy": {
        "type": "AUTOMERGE"
      }
    }
  }
}